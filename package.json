{
  "name": "paroxysm-launcher",
  "version": "0.1.20",
  "description": "Paroxysm Launcher — The final Minecraft launcher",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "extract-zip": "^2.0.1",
    "follow-redirects": "^1.15.6",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "dev.paroxysm.launcher",
    "productName": "Paroxysm Launcher",
    "copyright": "Copyright © 2026 Seoloon",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Paroxysm Launcher",
      "createDesktopShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "artifactName": "Paroxysm-Setup-${version}.${ext}"
    },
    "files": ["src/**/*", "assets/**/*"]
  }
}