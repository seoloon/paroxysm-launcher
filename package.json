{
  "name": "paroxysm-launcher",
  "version": "1.0.0-beta",
  "description": "Paroxysm Launcher — The final Minecraft launcher",
  "author": "Seoloon",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/i18n.js && node --check src/renderer/renderer.js",
    "build:win": "electron-builder --win",
    "build:win:release": "npm run check && electron-builder --win --publish never",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:all": "npm run check && electron-builder --win --linux --mac --publish never"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2",
    "extract-zip": "^2.0.1",
    "follow-redirects": "^1.15.6",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "dev.paroxysm.launcher",
    "productName": "Paroxysm Launcher",
    "copyright": "Copyright © 2026 Seoloon",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Paroxysm Launcher",
      "createDesktopShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "artifactName": "Paroxysm-Setup-${version}.${ext}"
    },
    "generateUpdatesFilesForAllChannels": true,
    "publish": [
      {
        "provider": "github",
        "owner": "seoloon",
        "repo": "paroxysm-launcher"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
